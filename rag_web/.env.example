# Django runtime settings
SECRET_KEY=replace_with_a_long_random_secret_key
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
# Main Django application database
DB_NAME=rag_app_db
DB_USER=rag_user
DB_PASSWORD=strongpassword
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=0

# Vector database with pgvector enabled
VECTOR_DB_NAME=rag_vector_db
VECTOR_DB_USER=vector_user
VECTOR_DB_PASSWORD=vectorpassword
VECTOR_DB_HOST=localhost
VECTOR_DB_PORT=5433

# LLM/API configuration
# Use OpenRouter when selecting OpenRouter models in the project settings.
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Use Vertex AI with Google Cloud Application Default Credentials.
VERTEX_AI_PROJECT=your_google_cloud_project_id
VERTEX_AI_LOCATION=us-central1

# Optional Google Generative AI API key, only needed when using google-genai based flows.
GOOGLE_API_KEY=your_google_api_key_here

# Local Ollama configuration, used when selecting Ollama as the project provider.
OLLAMA_BASE_URL=http://localhost:11434

# LLM rate limiting
MAX_LLM_TOKENS_PER_MINUTE=1200000
MAX_LLM_REQUESTS_PER_MINUTE=45
LLM_RATE_LIMIT_POLL_SECONDS=0.05

# Auto-generation worker settings
TOPIC_PIPELINE_WORKERS=2
VISUAL_PIPELINE_WORKERS=2
VISUAL_REPAIR_WORKERS=2
SQL_PLACEHOLDER_WORKERS=3
SQL_INSIGHT_WORKERS=2
SQL_INSIGHT_BATCH_SIZE=2

